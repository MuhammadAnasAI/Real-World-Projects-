    "# \n",
    "\n",
    "# %%\n",
    "# Function to display random images\n",
    "def display_random_images(X, y, class_names, num_images=25):\n",
    "    plt.figure(figsize=(12, 12))\n",
    "    for i in range(num_images):\n",
    "        plt.subplot(5, 5, i+1)\n",
    "        idx = np.random.randint(0, X.shape[0])\n",
    "        plt.imshow(X[idx])\n",
    "        plt.title(class_names[y[idx][0]])\n",
    "        plt.axis('off')\n",
    "    plt.suptitle('Random CIFAR-10 Images', fontsize=16, fontweight='bold')\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "# Display random images\n",
    "display_random_images(X_train, y_train, class_names)\n",
    "\n",
    "# %%\n",
    "# Class distribution analysis\n",
    "train_class_distribution = pd.Series(y_train.flatten()).value_counts().sort_index()\n",
    "\n",
    "plt.figure(figsize=(12, 6))\n",
    "colors = plt.cm.viridis(np.linspace(0, 1, 10))\n",
    "bars = plt.bar(class_names, train_class_distribution.values, color=colors)\n",
    "plt.title('Class Distribution in Training Set', fontsize=16, fontweight='bold')\n",
    "plt.xlabel('Classes', fontsize=12)\n",
    "plt.ylabel('Number of Samples', fontsize=12)\n",
    "plt.xticks(rotation=45)\n",
    "\n",
    "# Add value labels on bars\n",
    "for bar, count in zip(bars, train_class_distribution.values):\n",
    "    plt.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 5,\n",
    "             str(count), ha='center', va='bottom', fontsize=10)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(f\"вң… Dataset is perfectly balanced: {train_class_distribution.values[0]} images per class\")\n",
    "\n",
    "# %%\n",
    "# Display grid of images from each class\n",
    "fig, axes = plt.subplots(10, 5, figsize=(15, 25))\n",
