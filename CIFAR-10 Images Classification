ss', fontsize=16, fontweight='bold')\n\nfor i, ax in enumerate(axes.flat):\n    ax.plot(fpr[i], tpr[i], color='darkorange', lw=2, \n            label=f'ROC curve (AUC = {roc_auc[i]:.3f})')\n    ax.plot([0, 1], [0, 1], color='navy', lw=2, linestyle='--', label='Random')\n    ax.set_xlim([0.0, 1.0])\n    ax.set_ylim([0.0, 1.05])\n    ax.set_xlabel('False Positive Rate')\n    ax.set_ylabel('True Positive Rate')\n    ax.set_title(f'{class_names[i]}')\n    ax.legend(loc=\"lower right\", fontsize=8)\n    ax.grid(True, alpha=0.3)\n\nplt.tight_layout()\nplt.show()\n\n# %%\n# Compute micro and macro average ROC curves\nfrom sklearn.metrics import roc_auc_score\n\n# Micro-average\nfpr_micro, tpr_micro, _ = roc_curve(y_test_bin.ravel(), y_pred_probs.ravel())\nroc_auc_micro = auc(fpr_micro, tpr_micro)\n\n# Macro-average\nall_fpr = np.unique(np.concatenate([fpr[i] for i in range(n_classes)]))\nmean_tpr = np.zeros_like(all_fpr)\nfor i in range(n_classes):\n    mean_tpr += np.interp(all_fpr, fpr[i], tpr[i])\nmean_tpr /= n_classes\nroc_auc_macro = auc(all_fpr, mean_tpr)\n\n# Plot average ROC curves\nplt.figure(figsize=(10, 8))\nplt.plot(fpr_micro, tpr_micro, color='blue', lw=3, \n         label=f'Micro-average ROC (AUC = {roc_auc_micro:.3f})')\nplt.plot(all_fpr, mean_tpr, color='red', lw=3, \n         label=f'Macro-average ROC (AUC = {roc_auc_macro:.3f})')\nplt.plot([0, 1], [0, 1], color='gray', lw=2, linestyle='--', label='Random Classifier')\nplt.xlim([0.0, 1.0])\nplt.ylim([0.0, 1.05])\nplt.xlabel('False Positive Rate', fontsize=12)\nplt.ylabel('True Positive Rate', fontsize=12)\nplt.title('Average ROC Curves', fontsize=14, fontweight='bold')\nplt.legend(loc=\"lower right\")\nplt.grid(True, alpha=0.3)\nplt.tight_layout()\nplt.show()\n\nprint(f\"\\n📊 AUC Scores:\")\nprint(f\"   • Micro-average AUC: {roc_auc_micro:.4f}\")\nprint(f\"   • Macro-average AUC: {roc_auc_macro:.4f}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-07T12:08:29.802294Z","iopub.execute