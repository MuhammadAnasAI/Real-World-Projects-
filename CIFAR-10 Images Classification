ain min value: 0.000\n   • X_train max value: 1.000\n   • X_train mean value: 0.473\n","output_type":"stream"}],"execution_count":7},{"cell_type":"markdown","source":"## 6. Data Augmentation","metadata":{}},{"cell_type":"code","source":"# \n\n# %%\n# Create data augmentation generator\ndatagen = ImageDataGenerator(\n    rotation_range=15,\n    width_shift_range=0.1,\n    height_shift_range=0.1,\n    horizontal_flip=True,\n    zoom_range=0.1,\n    shear_range=0.1,\n    fill_mode='nearest'\n)\n\n# Fit the generator to training data\ndatagen.fit(X_train)\n\n# Visualize augmented images\nfig, axes = plt.subplots(2, 6, figsize=(15, 6))\nfig.suptitle('Original vs Augmented Images', fontsize=16, fontweight='bold')\n\n# Select random images\nfor row in range(2):\n    idx = np.random.randint(0, len(X_train))\n    original_image = X_train[idx]\n    \n    # Display original\n    axes[row, 0].imshow(original_image)\n    axes[row, 0].set_title('Original', fontsize=10)\n    axes[row, 0].axis('off')\n    \n    # Display 5 augmented versions\n    for col in range(1, 6):\n        augmented = datagen.random_transform(original_image)\n        axes[row, col].imshow(augmented)\n        axes[row, col].set_title(f'Augmented {col}', fontsize=10)\n        axes[row, col].axis('off')\n\nplt.tight_layout()\nplt.show()\n\nprint(\"✅ Data augmentation configured successfully\")\nprint(f\"   • Rotation range: 15 degrees\")\nprint(f\"   • Width shift: 10%\")\nprint(f\"   • Height shift: 10%\")\nprint(f\"   • Horizontal flip: Enabled\")\nprint(f\"   • Zoom range: 10%\")\nprint(f\"   • Shear range: 10%\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-07T11:55:48.325862Z","iopub.execute_input":"2026-03-07T11:55:48.326115Z","iopub.status.idle":"2026-03-07T11:55:49.306547Z","shell.execute_reply.started":"2026-03-07T11:55:48.326095Z","shell.execute_reply":"2026-03-07T11:55:49.305900Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1500x600 with 12 