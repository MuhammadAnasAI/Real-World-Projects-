      possible_id_cols = ['image_id', 'id', 'img_id', 'ImageID', 'filename']\n        self.id_col = None\n        for col in possible_id_cols:\n            if col in self.df.columns:\n                self.id_col = col\n                break\n        if self.id_col is None:\n            self.id_col = self.df.columns[0]\n            print(f\"⚠️ No standard ID column found. Using '{self.id_col}' as ID column.\")\n        else:\n            print(f\"✅ Found ID column: '{self.id_col}'\")\n        \n        # --- Auto-detect Labels ---\n        self.labels = []\n        self.valid_indices = []\n        \n        if all(cls in self.df.columns for cls in config.CLASSES):\n            print(\"✅ Detected One-Hot encoded labels.\")\n            for idx, row in self.df.iterrows():\n                for i, cls in enumerate(config.CLASSES):\n                    if row[cls] == 1:\n                        self.labels.append(i)\n                        self.valid_indices.append(idx)\n                        break\n        else:\n            possible_label_cols = ['dx', 'label', 'diagnosis', 'class']\n            label_col = None\n            for col in possible_label_cols:\n                if col in self.df.columns:\n                    label_col = col\n                    break\n            if label_col is None:\n                raise KeyError(f\"No label column found. Available: {self.df.columns.tolist()}\")\n            print(f\"✅ Detected single label column: '{label_col}'. Mapping strings to integers.\")\n            unique_labels = self.df[label_col].unique()\n            label_to_idx = {lbl: i for i, lbl in enumerate(sorted(unique_labels))}\n            for idx, row in self.df.iterrows():\n                raw_label = row[label_col]\n                if raw_label in config.CLASSES:\n                    mapped_idx = config.CLASSES.index(raw_label)\n                else:\n                    mapped_idx = label_to_idx[raw_label]\n                self.labels.append(mapped_idx)\n                self.valid_indices.append(idx)\n        \n        self.df = self.df.loc[self.valid_indices].reset_index(drop=True)\n        class_counts = np.bincount(self.labels)\n        print(f\"Loaded {len(self.df)} samples.\")\n        print(f\"Class distribution: {dict(zip(range(len(config.CLASSES)), class_counts))}\")\n        \n    def __len__(self):\n        return len(self.df)\n    \n    def __getitem__(self, idx):\n        row = self.df.iloc[idx]\n        img_id = row[self.id_col]\n        if img_id.endswith('.jpg') or img_id.endswith('.png'):\n            img_id = img_id.split('.')[0]\n        label = self.labels[idx]\n        \n        # Load image\n        img_path = os.path.join(self.img_dir, f\"{img_id}.jpg\")\n        if not os.path.exists(img_path):\n            img_path = os.path.join(self.img_dir, f\"{img_id}.png\")\n        if not os.path.exists(img_path):\n            # Try to find any file starting with the ID\n            possible = [f for f in os.listdir(self.img_dir) if f.startswith(img_id)]\n            if possible:\n                img_path = os.path.join(self.img_dir, possible[0])\n            else:\n                raise FileNotFoundError(f\"Image not found: {img_id}\")\n        \n        image = plt.imread(img_path)\n        if image.ndim == 2:\n            image = np.stack([image]*3, axis=-1)\n        elif image.shape[-1] == 4:\n            image = image[..., :3]\n        image = torch.from_numpy(image).permute(2, 0, 1).float() / 255.0\n        \n        # Load mask\n        mask_path = os.path.join(self.mask_dir, f\"{img_id}.png\")\n        if not os.path.exists(mask_path):\n            possible_masks = [f for f in os.listdir(self.mask_dir) if f.startswith(img_id)]\n            if possible_masks:\n                mask_path = os.path.join(self.mask_dir, possible_masks[0])\n            else:\n                # missing mask → use dummy (full image)\n                mask = torch.ones(image.shape[1:]).float()\n                mask_path = None\n        \n        if mask_path and os.path.exists(mask_path):\n            mask = plt.imread(mask_path)\n            if mask.ndim == 3:\n                mask = mask[:, :, 0]\n            mask = torch.from_numpy(mask).float()\n        else:\n            mask = torch.ones(image.shape[1:]).float()\n        \n        # --- ROI Cropping ---\n        mask_np = mask.numpy()\n        coords = np.where(mask_np > 0.5)\n        if len(coords[0]) > 0 and len(coords[1]) > 0:\n            y_min, y_max = max(0, coords[0].min() - 5), min(mask_np.shape[0], coords[0].max() + 5)\n            x_min, x_max = max(0, coords[1].min() - 5), min(mask_np.shape[1], coords[1].max() + 5)\n        else:\n            h, w = mask_np.shape\n            y_min, y_max = h//4, 3*h//4\n            x_min, x_max = w//4, 3*w//4\n        \n        image = image[:, y_min:y_max, x_min:x_max]\n        mask = mask[y_min:y_max, x_min:x_max]\n        \n        # Resize\n        image = TF.resize(image, (config.IMG_SIZE, config.IMG_SIZE), antialias=True)\n        mask = TF.resize(mask.unsqueeze(0), (config.IMG_SIZE, config.IMG_SIZE),\n                         interpolation=TF.InterpolationMode.NEAREST).squeeze(0)\n        mask = (mask > 0.5).float()\n        \n        # --- Apply spatial transforms (if any) to both image and mask ---\n        if self.spatial_transform is not None:\n            # stack: 3 channels image + 1 channel mask => 4 channels\n            stacked = torch.cat([image, mask.unsqueeze(0)], dim=0)\n            stacked = self.spatial_transform(stacked)\n            image = stacked[:3, ...]\n            mask = stacked[3:, ...].squeeze(0)\n        \n        # --- Apply image augmentation (e.g., RandAugment) to image only ---\n        if self.image_aug is not None:\n            image = self.image_aug(image)  # operates only on 3-channel image\n        \n        return image, mask, label, img_id","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-17T05:07:21.705292Z","iopub.execute