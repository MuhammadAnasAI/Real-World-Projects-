.Conv2d(in_channels, out_channels, 3, padding=dilations[1], dilation=dilations[1], bias=False)\n        self.conv4 = nn.Conv2d(in_channels, out_channels, 3, padding=dilations[2], dilation=dilations[2], bias=False)\n        self.global_avg = nn.AdaptiveAvgPool2d(1)\n        self.conv_global = nn.Conv2d(in_channels, out_channels, 1, bias=False)\n        self.bn = nn.BatchNorm2d(out_channels * 5)\n        self.relu = nn.ReLU(inplace=True)\n        self.project = nn.Conv2d(out_channels * 5, out_channels, 1, bias=False)\n        \n    def forward(self, x):\n        x1 = self.conv1(x)\n        x2 = self.conv2(x)\n        x3 = self.conv3(x)\n        x4 = self.conv4(x)\n        x5 = self.global_avg(x)\n        x5 = self.conv_global(x5)\n        x5 = F.interpolate(x5, size=x.shape[2:], mode='bilinear', align_corners=True)\n        out = torch.cat([x1, x2, x3, x4, x5], dim=1)\n        out = self.bn(out)\n        out = self.relu(out)\n        out = self.project(out)\n        return out\n\nclass MultiTaskSwinDeepLab(nn.Module):\n    def __init__(self, num_classes=7):\n        super().__init__()\n        self.backbone = timm.create_model('swin_tiny_patch4_window7_224', \n                                          pretrained=True, features_only=True)\n        backbone_channels = [96, 192, 384, 768]\n        \n        self.aspp = ASPP(backbone_channels[-1], 256)\n        \n        self.decoder = nn.Sequential(\n            nn.Conv2d(backbone_channels[-2], 48, 1, bias=False),\n            nn.BatchNorm2d(48),\n            nn.ReLU(inplace=True)\n        )\n        self.final_conv = nn.Sequential(\n            nn.Conv2d(256 + 48, 256, 3, padding=1, bias=False),\n            nn.BatchNorm2d(256),\n            nn.ReLU(inplace=True),\n            nn.Conv2d(256, 1, 1)  # raw logits (no sigmoid)\n        )\n        \n        # Classification head\n        hidden_dim = backbone_channels[-1]\n        self.mha_pool = nn.MultiheadAttention(embed_dim=hidden_dim, num_heads=8, batch_first=True)\n        self.cls_token = nn.Parameter(torch.randn(1, 1, hidden_dim))\n        self.cls_head = nn.Linear(hidden_dim, num_classes)\n        self.dropout = nn.Dropout(p=0.2)\n        \n    def forward(self, x):\n        features = self.backbone(x)  # NHWC\n        # Permute to NCHW\n        features_nchw = [f.permute(0, 3, 1, 2).contiguous() for f in features]\n        f3, f4 = features_nchw[-2], features_nchw[-1]\n        \n        # Segmentation branch (raw logits)\n        aspp_out = self.aspp(f4)\n        aspp_out = F.interpolate(aspp_out, size=f3.shape[2:], mode='bilinear', align_corners=True)\n        low_feat = self.decoder(f3)\n        concat = torch.cat([aspp_out, low_feat], dim=1)\n        seg_logits = self.final_conv(concat)\n        seg_logits = F.interpolate(seg_logits, size=x.shape[2:], mode='bilinear', align_corners=True)\n        # No sigmoid - return logits\n        \n        # Classification\n        B, C, H, W = f4.shape\n        tokens = f4.flatten(2).permute(0, 2, 1)\n        cls_token = self.cls_token.expand(B, -1, -1)\n        pooled, _ = self.mha_pool(cls_token, tokens, tokens)\n        pooled = pooled.squeeze(1)\n        pooled = self.dropout(pooled)\n        cls_logits = self.cls_head(pooled)\n        \n        return seg_logits, cls_logits\n\n# Initialize model\nmodel = MultiTaskSwinDeepLab(num_classes=7).to(device)\nif torch.cuda.device_count() > 1:\n    print(f\"Using {torch.cuda.device_count()} GPUs!\")\n    model = nn.DataParallel(model)\nprint(f\"Model parameters: {sum(p.numel() for p in model.parameters()):,}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-17T05:07:38.638738Z","iopub.execute_input":"2026-07-17T05:07:38.639208Z","iopub.status.idle":"2026-07-17T05:07:39.36037Z","shell.execute_reply.started":"2026-07-17T05:07:38.639179Z","shell.execute_reply":"2026-07-17T05:07:39.35956Z"}},"outputs":[{"name":"stdout","text":"Using 2 GPUs!\nModel parameters: 36,637,922\n","output_type":"stream"}],"execution_count":32},{"cell_type":"code","source":"# Cell 6: Loss Functions - autocast-safe\nclass DiceLoss(nn.Module):\n    def __init__(self, smooth=1e-6):\n        super().__init__()\n        self.smooth = smooth\n    def forward(self, logits, target):\n        # Apply sigmoid to get probabilities\n        pred = torch.sigmoid(logits)\n        pred = pred.contiguous().view(-1)\n        target = target.contiguous().view(-1)\n        intersection = (pred * target).sum()\n        dice = (2. * intersection + self.smooth) / (pred.sum() + target.sum() + self.smooth)\n        return 1 - dice\n\nclass BinaryFocalLoss(nn.Module):\n    def __init__(self, alpha=0.75, gamma=2.0):\n        super().__init__()\n        self.alpha = alpha\n        self.gamma = gamma\n    def forward(self, logits, target):\n        # Use BCEWithLogitsLoss internally (autocast-safe)\n        bce = F.binary_cross_entropy_with_logits(logits, target, reduction='none')\n        pred = torch.sigmoid(logits)\n        pt = torch.where(target == 1, pred, 1 - pred)\n        focal = self.alpha * (1 - pt)**self.gamma * bce\n        return focal.mean()\n\n# Combined segmentation loss\ndef get_seg_loss(logits, target):\n    # logits: raw outputs from model, target: binary mask [0,1]\n    dice = DiceLoss()(logits, target)\n    bce = F.binary_cross_entropy_with_logits(logits, target)  # built-in, autocast-safe\n    focal = BinaryFocalLoss()(logits, target)\n    return dice + 0.5 * bce + 0.5 * focal","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-17T05:07:44.226227Z","iopub.execute_input":"2026-07-17T05:07:44.226631Z","iopub.status.idle":"2026-07-17T05:07:44.234131Z","shell.execute_reply.started":"2026-07-17T05:07:44.226604Z","shell.execute_reply":"2026-07-17T05:07:44.233317Z"}},"outputs":[],"execution_count":33},{"cell_type":"code","source":"# Cell 7: Training & Validation Loops\nfrom sklearn.metrics import jaccard_score\nfrom collections import defaultdict\n\nwriter = SummaryWriter(config.TENSORBOARD_DIR)\nsc